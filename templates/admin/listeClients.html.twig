{% extends 'admin_layout.html.twig' %}

{% block FormArmor_body %}
<h2>Gestion des clients</h2>

{# --- Choix du client --- #}
<select id="clientSelect">
    <option value="">-- Choisir un client --</option>
    {% for client in clients %}
        <option value="{{ client.id }}">{{ client.username }}</option>
    {% endfor %}
</select>

{# --- Choix de la formation --- #}
<select id="formationSelect">
    <option value="">-- Choisir une formation --</option>
    <option value="compta">Compta</option>
    <option value="bureautique">Bureautique</option>
</select>

{# --- Tableau --- #}
<br><br>
<table id="tableClient" style="display:none; width: 70%; border-collapse: collapse; margin-top: 10px;">
    <thead>
        <tr style="background-color: #4CAF50; color: white;">
            <th style="padding: 8px; border: 1px solid #ddd;">Nom</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Prénom</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Heures Compta</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Heures Bureautique</th>
        </tr>
    </thead>
    <tbody id="clientData" style="border: 1px solid #ddd;"></tbody>
</table>

<style>
    #tableClient tr:nth-child(even) { background-color: #f2f2f2; }
    #tableClient tr:hover { background-color: #ddd; }
    #tableClient th { text-align: left; }
</style>

<script>
function loadClientData() {
    const clientId = document.getElementById('clientSelect').value;
    const formation = document.getElementById('formationSelect').value;

    if (!clientId || !formation) {
        document.getElementById('tableClient').style.display = 'none';
        return;
    }

    fetch("{{ path('client_info_ajax') }}?id=" + clientId)
        .then(response => response.json())
        .then(data => {
            if (data.error) return;

            let heuresCompta = 0;
            let heuresBureautique = 0;

            if (formation === 'compta') {
                heuresCompta = data.heuresCompta;
            } else if (formation === 'bureautique') {
                heuresBureautique = data.heuresBureautique;
            }

            document.getElementById('clientData').innerHTML = `
                <tr>
                    <td>${data.nom || data.username}</td>
                    <td>${data.prenom || '-'}</td>
                    <td>${heuresCompta}</td>
                    <td>${heuresBureautique}</td>
                </tr>
            `;

            document.getElementById('tableClient').style.display = 'table';
        })
        .catch(error => console.error('Erreur AJAX :', error));
}

document.getElementById('clientSelect').addEventListener('change', loadClientData);
document.getElementById('formationSelect').addEventListener('change', loadClientData);
</script>
{% endblock %}