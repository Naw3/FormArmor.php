{% extends 'admin_layout.html.twig' %}
{% block title %}Creation de compte client !{% endblock %}

{% block FormArmor_body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<h3>Formulaire de saisie des clients</h3>

<div class="well">
  {{ form_start(form, {'attr': {'class': 'form-horizontal'}}) }}

  {# Les erreurs générales du formulaire. #}
  {{ form_errors(form) }}

  {# Champs existants #}
  {{ form_row(form.username) }}
  {{ form_row(form.password) }}
  {{ form_row(form.roles) }}

  {# --- Nouveaux champs ajoutés : nom et prenom --- #}
  {{ form_row(form.nom) }}
  {{ form_row(form.prenom) }}

  {# A COMPLETER PAR LES AUTRES CHAMPS DE L'ENTITY CLIENT (adresse, cp, ville...) #}

  {# Bouton d'enregistrement #}
  {{ form_widget(form.enregistrer, {'attr': {'class': 'btn btn-primary'}}) }}

  {# Génération automatique des champs cachés / CSRF #}
  {{ form_rest(form) }}
  
  {{ form_end(form) }}
</div>
{% endblock %}